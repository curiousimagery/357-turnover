# Copy to .env.local and fill in. .env.local is git-ignored. Never commit real keys.
#
# ── Connecting Supabase (pick one) ──────────────────────────────────────────
#
# A) Local Supabase (recommended; matches our reliability rule — schema changes
#    are tested locally first). Requires Docker. Then:
#       npx supabase start
#    It prints an API URL and an anon (publishable) key. Use them below.
#    Magic-link emails are caught locally at http://127.0.0.1:54324 (Inbucket).
#
# B) Hosted free project: Project Settings > API. Use the project URL and the
#    publishable (anon) key. Never put the service-role/secret key in any
#    NEXT_PUBLIC_* variable — it must stay server-side only.

NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key

# ── Server-only secrets (added in later phases; never exposed to the client) ──
# SUPABASE_SECRET_KEY=your-service-role-key
# AIRBNB_ICAL_URL=the-tokenized-listing-export-url
# RESEND_API_KEY=your-resend-key
# PROPERTY_TIMEZONE=America/Los_Angeles
# POLL_INTERVAL=hourly
